# ~/.config/kanshi/config

profile docked {
    output HDMI-A-1 {
        enable
        position 0,0
        scale 1.25
        mode 1920x1080@100Hz
        transform normal
    }

    output eDP-1 {
        enable
        position -1152,0
        scale 1.25
        mode 1440x900@60Hz
    }
}

profile laptop-only {
    output eDP-1 {
        enable
        position 0,0
        scale 1.25
        mode 1440x900@60Hz
    }

    output HDMI-A-1 {
        disable
    }
}
